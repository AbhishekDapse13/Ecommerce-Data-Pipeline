    SELECT 
        o.order_id, 
        c.name AS customer_name, 
        o.order_date, 
        s.status, 
        s.shipped_at, 
        s.delivered_at,
        DATEDIFF('minute', s.shipped_at, s.delivered_at)/60AS delivery_hours
