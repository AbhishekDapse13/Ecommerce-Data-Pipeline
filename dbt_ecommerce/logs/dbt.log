    JOIN ecommerce_db.analytics.stg_customers c ON o.customer_id = c.customer_id
)
SELECT 
    *,
    CASE 
        WHEN status = 'shipped' AND delivery_hours > 48 THEN 'DELAYED' 
        ELSE status 
    END AS final_status
FROM base
  )
