  as (
    WITH base AS ( 
    SELECT 
        o.order_id, 
        c.name AS customer_name, 
        o.order_date, 
        s.status, 
        -- Cast to ensure we aren't using truncated dates
        s.shipped_at::TIMESTAMP AS shipped_ts, 
        s.delivered_at::TIMESTAMP AS delivered_ts, 
        -- Use seconds for max precision
        (DATEDIFF('second', shipped_ts, delivered_ts) / 3600.0) AS delivery_hours 
    FROM ecommerce_db.raw.orders o 
    JOIN ecommerce_db.raw.shipments s ON o.order_id = s.order_id 
    JOIN ecommerce_db.raw.customers c ON o.customer_id = c.customer_id 
)
SELECT 
    *,
    CASE 
        WHEN status = 'shipped' AND delivery_hours > 48 THEN 'DELAYED' 
        ELSE status 
    END AS final_status
FROM base
  )
