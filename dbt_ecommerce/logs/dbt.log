  as (
    WITH base AS (
    SELECT 
        o.order_id, 
        c.name AS customer_name, 
        o.order_date, 
        s.status, 
        s.shipped_at, 
        s.delivered_at,
        DATEDIFF('minute', s.shipped_at, s.delivered_at) AS delivery_hours
    FROM ecommerce_db.analytics.stg_orders o
    JOIN ecommerce_db.analytics.stg_shipments s ON o.order_id = s.order_id
    JOIN ecommerce_db.analytics.stg_customers c ON o.customer_id = c.customer_id
)
SELECT 
    *,
    CASE 
        WHEN status = 'shipped' AND delivery_hours > 48 THEN 'DELAYED' 
        ELSE status 
    END AS final_status
FROM base
  )
